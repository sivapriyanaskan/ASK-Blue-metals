# --- Runtime ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
# Point to a local Postgres database; create it with `createdb ask_blue_metal`
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ask_blue_metal?schema=public

# --- JWT ---
# In production, switch to RS256 with PEM key files (see README hardening notes).
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_ISSUER=ask-blue-metal
JWT_AUDIENCE=ask-clients
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Cookies (for browser refresh-token transport) ---
COOKIE_SECRET=replace-with-a-long-random-string-at-least-16-chars

# --- Account lockout policy ---
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_WINDOW_MIN=15

# --- Seed defaults (used by `npm run db:seed`) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@askbluemetal.local
SEED_ADMIN_PASSWORD=Admin@12345678
